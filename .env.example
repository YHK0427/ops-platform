# ── Database ──────────────────────────────────────
POSTGRES_DB=univpt_ops
POSTGRES_USER=univpt
POSTGRES_PASSWORD=CHANGE_ME_STRONG_32CHAR+
DATABASE_URL=postgresql+asyncpg://univpt:CHANGE_ME_STRONG_32CHAR+@db:5432/univpt_ops

# ── Redis ─────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PW
REDIS_URL=redis://:CHANGE_ME_REDIS_PW@redis:6379/0

# ── Auth ──────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$...   # bcrypt 해시
# 생성: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpw', bcrypt.gensalt()).decode())"
JWT_SECRET_KEY=CHANGE_ME_64CHAR_RANDOM_HEX
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440          # 24시간

# ── Naver ─────────────────────────────────────────
NAVER_IMAP_EMAIL=club_email@naver.com
NAVER_IMAP_PASSWORD=앱비밀번호
NAVER_CAFE_ID=31668555
NAVER_CAFE_MENU_VIDEO=1
NAVER_CAFE_MENU_REVIEW=2
NAVER_CAFE_MENU_PPT=3

# ── Google Drive ──────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── App ───────────────────────────────────────────
# (GENERATION 제거됨 — 기수는 DB cohorts 테이블로 관리)
CORS_ORIGINS=https://ops.univpt.com   # Cloudflare Tunnel 도메인만 허용

# ── Telegram Logging ────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
TELEGRAM_AUDIT_CHAT_ID=

# ── Web Push (VAPID) ────────────────────────────
# 키쌍 생성: python -c "import base64;from cryptography.hazmat.primitives.asymmetric import ec;from cryptography.hazmat.primitives import serialization;p=ec.generate_private_key(ec.SECP256R1());print('PUB',base64.urlsafe_b64encode(p.public_key().public_bytes(serialization.Encoding.X962,serialization.PublicFormat.UncompressedPoint)).rstrip(b'=').decode());print('PRIV',base64.urlsafe_b64encode(p.private_numbers().private_value.to_bytes(32,'big')).rstrip(b'=').decode())"
# ⚠️ dev/prod 동일 키 사용해야 함(공개키가 구독에 박힘). prod .env에도 같은 값 주입.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@univpt.com

# ── Environment ─────────────────────────────────
ENV=dev                         # production 시 API docs 비활성화
